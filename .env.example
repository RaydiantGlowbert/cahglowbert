# Frontend (Vite)
# URL of the multiplayer server used by Remote mode in the browser.
VITE_SERVER_URL=http://localhost:3001

# Server
# Port for the multiplayer server.
PORT=3001

# Optional CORS allowlist for the multiplayer server.
# Comma-separated origins, for example:
# CORS_ORIGIN=https://your-frontend.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Room storage backend
# Options: file | redis
ROOM_STORE=file

# Redis URL (required when ROOM_STORE=redis).
# Example: redis://localhost:6379
REDIS_URL=
